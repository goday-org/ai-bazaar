root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{rs,go}]
indent_size = 4

[*.md]
# Markdown spec treats trailing spaces as line breaks; do not trim.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.sol]
indent_size = 4
